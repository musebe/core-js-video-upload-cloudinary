# ─────────────────────────────────────────────────────────────────────────────
# Cloudinary Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Your Cloudinary cloud name.
# Found at: https://console.cloudinary.com → Dashboard → Cloud name
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name

# An *unsigned* upload preset.
# Create one at: Cloudinary Console → Settings → Upload → Upload presets → Add preset
# Set "Signing Mode" to "Unsigned".
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset

# Admin API credentials — required only for the rename feature in the gallery.
# Found at: https://console.cloudinary.com → Dashboard → API Keys
# ⚠️  DEMO ONLY: never expose API_SECRET in a production frontend. Use a backend proxy instead.
VITE_CLOUDINARY_API_KEY=your-api-key
VITE_CLOUDINARY_API_SECRET=your-api-secret
